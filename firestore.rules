rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Hilfsfunktion für den Server (unauthentifizierter Zugriff vom Backend-Server)
    function isServer() {
      return request.auth == null;
    }

    // Hauptregelblock: Erlaubt Lese- und Schreibzugriff für alle angemeldeten Benutzer 
    // sowie für den Backend-Server.
    match /{document=**} {
      allow read, write: if request.auth != null || isServer();
    }
    
    // Spezifische Pfad-Definitionen können hier bei Bedarf für feinere Granularität 
    // (z.B. PII-Schutz) hinzugefügt werden, folgen aber aktuell der obigen globalen Regel.
  }
}
